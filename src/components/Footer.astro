---
const socialLinks = [
  { href: "https://github.com/jasonedwardnicoll", label: "GitHub" },
  { href: "https://x.com/jasonedward97", label: "X" },
  { href: "https://www.linkedin.com/in/jedwardnicoll", label: "LinkedIn" },
  { href: "mailto:hello@jasonedward.me", label: "Email" },
];
---

<footer class="w-full mt-auto">
  <hr class="border-border" />
  <div class="flex flex-col items-center justify-between py-6 sm:flex-row-reverse sm:py-4">
    <div class="flex gap-4 mb-2 sm:mb-0">
      {socialLinks.map(({ href, label }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground/60 hover:text-accent transition-colors text-sm"
        >
          {label}
        </a>
      ))}
    </div>
    <div class="text-sm text-foreground/50">
      &copy; {new Date().getFullYear()} Jason Edward
    </div>
  </div>
</footer>
