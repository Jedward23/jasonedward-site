---
import '../styles/global.css'
import '../styles/components.css'

interface Props {
  title: string
  description?: string
}

const { title, description = "Jason Edward Nicoll — Building AI systems that work" } = Astro.props
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — jasonedward.me</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Header -->
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="header-name">Jason Edward</a>
        <nav class="header-nav-desktop">
          <a href="/">Home</a>
          <a href="/blog">Blog</a>
        </nav>
        <button class="hamburger" aria-label="Menu" onclick="document.querySelector('.mobile-menu').classList.toggle('open')">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
      <nav class="mobile-menu">
        <a href="/" onclick="document.querySelector('.mobile-menu').classList.remove('open')">Home</a>
        <a href="/blog" onclick="document.querySelector('.mobile-menu').classList.remove('open')">Blog</a>
      </nav>
    </header>

    <slot />

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background-color: var(--bg);
        border-bottom: 1px solid var(--bd);
      }

      .header-inner {
        max-width: 48rem;
        margin: 0 auto;
        padding: 0.875rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      @media (min-width: 640px) {
        .header-inner { padding: 0.875rem 2rem; }
      }

      @media (min-width: 768px) {
        .header-inner { padding: 0.875rem 3rem; }
      }

      .header-name {
        font-weight: 700;
        font-size: 1rem;
        color: var(--fg);
        text-decoration: none;
        letter-spacing: -0.01em;
      }

      .header-name:hover {
        color: var(--ac);
        opacity: 1;
      }

      .header-nav-desktop {
        display: none;
        gap: 1.5rem;
      }

      @media (min-width: 640px) {
        .header-nav-desktop {
          display: flex;
        }
        .hamburger {
          display: none !important;
        }
      }

      .header-nav-desktop a {
        font-size: 0.875rem;
        color: var(--mt);
        text-decoration: none;
        transition: color 0.2s;
        font-weight: 500;
      }

      .header-nav-desktop a:hover {
        color: var(--ac);
        opacity: 1;
      }

      /* Hamburger */
      .hamburger {
        display: flex;
        flex-direction: column;
        gap: 4px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
      }

      .hamburger-line {
        width: 20px;
        height: 2px;
        background-color: var(--fg);
        border-radius: 1px;
        transition: all 0.2s ease;
      }

      .hamburger:hover .hamburger-line {
        background-color: var(--ac);
      }

      /* Mobile menu */
      .mobile-menu {
        display: none;
        flex-direction: column;
        max-width: 48rem;
        margin: 0 auto;
        padding: 0 1.5rem 1rem;
        gap: 0.5rem;
      }

      .mobile-menu.open {
        display: flex;
      }

      @media (min-width: 640px) {
        .mobile-menu {
          display: none !important;
        }
      }

      .mobile-menu a {
        font-size: 0.9rem;
        color: var(--mt);
        text-decoration: none;
        padding: 0.5rem 0;
        transition: color 0.2s;
        font-weight: 500;
      }

      .mobile-menu a:hover {
        color: var(--ac);
        opacity: 1;
      }
    </style>
  </body>
</html>
