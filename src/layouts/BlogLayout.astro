---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  readTime?: string;
  slug?: string;
}

const { title, description, pubDate, readTime, slug } = Astro.props;
const shareUrl = `https://jasonedward.me/blog/${slug || ''}`;
const shareText = `${title} — by Jason Edward`;
---

<Layout title={title}>
  <article class="blog-article">
    <header class="mb-16">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">{title}</h1>
      <p class="text-lg text-muted mb-6">{description}</p>
      <div class="flex gap-4 text-sm text-muted">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {readTime && <span>·</span>}
        {readTime && <span>{readTime}</span>}
      </div>
    </header>

    <div class="prose prose-sm md:prose md:prose-lg max-w-none text-foreground leading-relaxed">
      <slot />
    </div>

    <!-- Share Section -->
    <div class="share-section">
      <div class="share-divider"></div>
      <p class="share-label">Share this post</p>
      <div class="share-buttons">
        <a
          href={`https://x.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="share-btn share-btn-x"
          title="Share on X"
        >
          <svg class="share-icon" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.514l-5.106-6.694-5.829 6.694h-3.328l7.706-8.813-8.169-10.687h6.564l4.784 6.333 5.314-6.333zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          <span>Post on X</span>
        </a>
        <a
          href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="share-btn share-btn-linkedin"
          title="Share on LinkedIn"
        >
          <svg class="share-icon" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
          </svg>
          <span>LinkedIn</span>
        </a>
        <button
          class="share-btn share-btn-copy"
          title="Copy link"
          data-url={shareUrl}
          onclick="
            navigator.clipboard.writeText(this.dataset.url).then(() => {
              const span = this.querySelector('span');
              const original = span.textContent;
              span.textContent = 'Copied!';
              this.classList.add('copied');
              setTimeout(() => { span.textContent = original; this.classList.remove('copied'); }, 2000);
            });
          "
        >
          <svg class="share-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <span>Copy link</span>
        </button>
      </div>
    </div>
  </article>

  <footer class="blog-footer">
    <p>© 2026 Jason Edward. All rights reserved.</p>
  </footer>
</Layout>

<style>
  .blog-article {
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    padding-top: 3rem;
    padding-bottom: 6rem;
  }

  @media (min-width: 640px) {
    .blog-article {
      padding-left: 2rem;
      padding-right: 2rem;
      padding-top: 4rem;
      padding-bottom: 6rem;
    }
  }

  @media (min-width: 768px) {
    .blog-article {
      padding-left: 3rem;
      padding-right: 3rem;
      padding-top: 6rem;
      padding-bottom: 8rem;
    }
  }

  :global(.prose) {
    --prose-body: var(--foreground);
    --prose-headings: var(--foreground);
    --prose-bold: var(--foreground);
    --prose-links: var(--accent);
    --prose-hr: var(--border);
    --prose-th-borders: var(--border);
    --prose-td-borders: var(--border);
  }

  :global(.prose strong) {
    color: var(--foreground);
    font-weight: 600;
  }

  :global(.prose h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  :global(.prose h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  :global(.prose p) {
    margin-bottom: 1.25rem;
    line-height: 1.75;
  }

  :global(.prose ul), :global(.prose ol) {
    margin-bottom: 1.25rem;
    margin-left: 1.5rem;
  }

  :global(.prose li) {
    margin-bottom: 0.5rem;
  }

  :global(.prose a) {
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  :global(.prose a:hover) {
    opacity: 0.8;
    text-decoration: underline;
  }

  /* Share Section */
  .share-section {
    margin-top: 4rem;
    padding-top: 2rem;
  }

  .share-divider {
    width: 3rem;
    height: 2px;
    background: var(--ac);
    margin-bottom: 1.5rem;
  }

  .share-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mt);
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .share-buttons {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    font-family: 'IBM Plex Mono', monospace;
    text-decoration: none;
    border: 1px solid var(--bd);
    color: var(--fg);
    background: transparent;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .share-btn:hover {
    border-color: var(--ac);
    color: var(--ac);
    transform: translateY(-1px);
    opacity: 1;
  }

  .share-btn:active {
    transform: translateY(0);
  }

  .share-btn.copied {
    border-color: #22c55e;
    color: #22c55e;
  }

  .share-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .blog-footer {
    margin-top: auto;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    padding-top: 3rem;
    padding-bottom: 3rem;
    text-align: center;
    font-size: 0.875rem;
    color: var(--muted);
    width: 100%;
  }

  @media (min-width: 640px) {
    .blog-footer {
      padding-left: 2rem;
      padding-right: 2rem;
      padding-top: 4rem;
      padding-bottom: 4rem;
    }
  }

  @media (min-width: 768px) {
    .blog-footer {
      padding-left: 3rem;
      padding-right: 3rem;
      padding-top: 6rem;
      padding-bottom: 6rem;
    }
  }
</style>
