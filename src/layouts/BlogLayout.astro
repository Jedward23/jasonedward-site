---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  readTime?: string;
  slug?: string;
}

const { title, description, pubDate, readTime, slug } = Astro.props;
const shareUrl = `https://jasonedward.me/blog/${slug || ''}`;
const shareText = `${title} — by Jason Edward`;
---

<Layout title={title} description={description}>
  <Header />
  <main class="mx-auto max-w-3xl px-4">
    <article class="pt-8 pb-12 sm:pt-12 sm:pb-16">
      <header class="mb-8">
        <h1 class="text-2xl sm:text-3xl font-bold mb-3">{title}</h1>
        <p class="text-base opacity-80 mb-4">{description}</p>
        <div class="flex gap-3 text-sm opacity-80">
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {readTime && <span>·</span>}
          {readTime && <span>{readTime}</span>}
        </div>
      </header>

      <div class="prose prose-sm sm:prose-base max-w-none">
        <slot />
      </div>

      <!-- Share Section -->
      <div class="mt-12 pt-6 border-t border-border">
        <p class="text-xs uppercase tracking-widest opacity-60 mb-3 font-semibold">Share this post</p>
        <div class="flex gap-3 flex-wrap">
          <a
            href={`https://x.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded text-sm border border-border hover:border-accent hover:text-accent transition-all"
            title="Share on X"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.514l-5.106-6.694-5.829 6.694h-3.328l7.706-8.813-8.169-10.687h6.564l4.784 6.333 5.314-6.333zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            <span>Post on X</span>
          </a>
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded text-sm border border-border hover:border-accent hover:text-accent transition-all"
            title="Share on LinkedIn"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
            </svg>
            <span>LinkedIn</span>
          </a>
          <button
            class="inline-flex items-center gap-2 px-4 py-2 rounded text-sm border border-border hover:border-accent hover:text-accent transition-all cursor-pointer"
            title="Copy link"
            data-url={shareUrl}
            onclick="
              navigator.clipboard.writeText(this.dataset.url).then(() => {
                const span = this.querySelector('span');
                const original = span.textContent;
                span.textContent = 'Copied!';
                this.style.borderColor = '#22c55e';
                this.style.color = '#22c55e';
                setTimeout(() => { span.textContent = original; this.style.borderColor = ''; this.style.color = ''; }, 2000);
              });
            "
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <span>Copy link</span>
          </button>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Layout>
