---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { getCollection } from 'astro:content'

const allPosts = await getCollection('blog')
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
---

<Layout title="Jason Edward Nicoll">
	<Header />
	<main id="main-content" class="mx-auto max-w-3xl px-4">
		<!-- Hero Section -->
		<section id="hero" class="pt-6 pb-4">
			<div class="flex flex-col sm:flex-row items-start gap-4">
				<a href="/" class="block mx-auto sm:mx-0">
					<img
						src="/jason-profile.jpg"
						alt="Jason Edward Nicoll"
						class="profile-image flex-shrink-0 transition-all duration-300 hover:scale-105 hover:shadow-xl"
					/>
				</a>
				<div class="flex-1 text-center sm:text-left">
					<div class="flex items-center gap-2 justify-center sm:justify-start">
						<h1 class="my-2 inline-block text-2xl font-bold sm:my-4 sm:text-3xl">
							Jason Edward
						</h1>
						<a
							href="/rss.xml"
							class="inline-block"
							aria-label="RSS feed"
							title="RSS Feed"
						>
							<svg class="w-5 h-5 stroke-accent stroke-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path d="M4 11a9 9 0 0 1 9 9"></path>
								<path d="M4 4a16 16 0 0 1 16 16"></path>
								<circle cx="5" cy="19" r="1"></circle>
							</svg>
						</a>
					</div>
					<p class="text-foreground/80">
						Building AI systems that work.
					</p>
					<!-- Social Links -->
					<div class="mt-4 flex flex-row items-center justify-center sm:justify-start gap-4">
						<a href="https://github.com/jasonedwardnicoll" target="_blank" rel="noopener noreferrer" title="GitHub" class="text-foreground/60 hover:text-accent transition-colors">
							<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
							</svg>
						</a>
						<a href="https://x.com/jasonedward97" target="_blank" rel="noopener noreferrer" title="X" class="text-foreground/60 hover:text-accent transition-colors">
							<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
								<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.514l-5.106-6.694-5.829 6.694h-3.328l7.706-8.813-8.169-10.687h6.564l4.784 6.333 5.314-6.333zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
							</svg>
						</a>
						<a href="https://www.linkedin.com/in/jedwardnicoll" target="_blank" rel="noopener noreferrer" title="LinkedIn" class="text-foreground/60 hover:text-accent transition-colors">
							<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
								<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
							</svg>
						</a>
						<a href="mailto:hello@jasonedward.me" title="Email" class="text-foreground/60 hover:text-accent transition-colors">
							<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
								<path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
							</svg>
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Horizontal Rule -->
		<hr class="border-border" />

		<!-- All Posts -->
		<section id="recent-posts" class="pt-12 pb-6">
			<ul>
				{posts.map((post) => (
					<li class="my-6">
						<a href={`/blog/${post.slug}`} class="inline-block text-lg font-medium decoration-dashed underline-offset-4 focus-visible:no-underline focus-visible:p-1 hover:text-accent">
							{post.data.title}
						</a>
						<div class="flex items-center gap-2 mt-1 text-sm opacity-80">
							<time datetime={post.data.pubDate.toISOString()}>
								{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
							</time>
							{post.data.readTime && (
								<>
									<span>·</span>
									<span>{post.data.readTime}</span>
								</>
							)}
						</div>
						<p class="mt-2 text-sm opacity-80">
							{post.data.description}
						</p>
					</li>
				))}
			</ul>
		</section>
	</main>
	<Footer />
</Layout>
