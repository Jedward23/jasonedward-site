---
import Layout from '../layouts/Layout.astro'
import ThemeToggle from '../components/ThemeToggle.astro'
---

<Layout title="Jason Edward Nicoll">
	<nav class="border-b sticky top-0 z-50 backdrop-blur-sm">
		<div class="max-w-2xl mx-auto px-6 md:px-8 py-4 flex justify-between items-center">
			<a href="/" class="text-lg md:text-xl font-bold">Jason Edward</a>
			<ThemeToggle />
		</div>
	</nav>

	<!-- Hero Section -->
	<section class="max-w-2xl mx-auto px-6 md:px-8 py-16 md:py-32">
		<div class="text-center mb-12">
			<div class="mb-8 flex justify-center">
				<img
					src="/jason-profile.jpg"
					alt="Jason Edward Nicoll"
					class="profile-image"
				/>
			</div>
			<h1 class="text-3xl md:text-4xl font-bold mb-3">Jason Edward</h1>
			<p class="text-lg md:text-xl text-muted mb-2">Building AI systems that work</p>
		</div>

		<!-- Social Links -->
		<div class="flex gap-6 justify-center mb-16 text-2xl">
			<a href="https://github.com" title="GitHub" class="transition hover:text-accent">
				<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
					<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
				</svg>
			</a>
			<a href="https://x.com/codius444" title="X" class="transition hover:text-accent">
				<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
					<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.514l-5.106-6.694-5.829 6.694h-3.328l7.706-8.813-8.169-10.687h6.564l4.784 6.333 5.314-6.333zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
				</svg>
			</a>
			<a href="https://www.linkedin.com/in/jason-edward-nicoll/" title="LinkedIn" class="transition hover:text-accent">
				<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
					<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
				</svg>
			</a>
			<a href="mailto:hello@jasonedward.me" title="Email" class="transition hover:text-accent">
				<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
					<path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
				</svg>
			</a>
		</div>

		<!-- Brief Bio -->
		<p class="text-center text-base md:text-lg leading-relaxed max-w-xl mx-auto text-muted mb-8">
			Founder of <strong class="text-foreground">Fern</strong> (AI Chief of Staff). CEO of <strong class="text-foreground">Frosted</strong> (email marketing). Building autonomous systems between Bali and Tokyo.
		</p>
	</section>

	<!-- Blog/Writing -->
	<section class="max-w-2xl mx-auto px-6 md:px-8 py-16 md:py-24 border-t" style="border-color: var(--border);">
		<h2 class="text-2xl md:text-3xl font-bold mb-12">Writing</h2>

		<!-- Blog items -->
		<div class="space-y-8">
			<article class="pb-8 border-b" style="border-color: var(--border);">
				<div class="flex items-baseline gap-3 mb-2">
					<a href="#" class="text-lg md:text-xl font-bold hover:text-accent transition">Building Real AI Systems</a>
					<span class="text-sm text-muted">5 min read</span>
				</div>
				<div class="text-sm text-muted mb-3">Mar 1, 2026</div>
				<p class="text-base leading-relaxed text-muted">
					What it actually takes to build AI systems that work in production, not just in demos.
				</p>
			</article>

			<article class="pb-8 border-b" style="border-color: var(--border);">
				<div class="flex items-baseline gap-3 mb-2">
					<a href="#" class="text-lg md:text-xl font-bold hover:text-accent transition">Voice Agents at Scale</a>
					<span class="text-sm text-muted">8 min read</span>
				</div>
				<div class="text-sm text-muted mb-3">Feb 28, 2026</div>
				<p class="text-base leading-relaxed text-muted">
					Lessons from building Codius, an autonomous voice agent that learns and improves over time.
				</p>
			</article>

			<article>
				<div class="flex items-baseline gap-3 mb-2">
					<a href="#" class="text-lg md:text-xl font-bold hover:text-accent transition">Email Marketing at 17 Clients</a>
					<span class="text-sm text-muted">12 min read</span>
				</div>
				<div class="text-sm text-muted mb-3">Feb 20, 2026</div>
				<p class="text-base leading-relaxed text-muted">
					How Frosted manages multiple clients with AI-powered email strategies and stays sane.
				</p>
			</article>
		</div>
	</section>

	<!-- Footer -->
	<footer class="border-t max-w-2xl mx-auto px-6 md:px-8 py-12 text-center text-sm text-muted" style="border-color: var(--border);">
		<p>© 2026 Jason Edward. All rights reserved.</p>
	</footer>
</Layout>
